# Notification Service Configuration

# Server Port
PORT=3001

# RabbitMQ Configuration
RABITMQ_URI=amqp://guest:guest@localhost:5672

# Email Service Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your_gmail_here@gmail.com
EMAIL_PASSWORD=your_app_password_here
REFRESH_TOKEN=your_oauth_refresh_token_here
EMAIL_FROM=noreply@sonity.com

# Database (if needed for notification history)
MONGO_URI=mongodb://localhost:27017/sonity_notifications
